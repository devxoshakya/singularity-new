{
  "name": "singularity",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "better-auth": "^1.3.28",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5",
      "@types/node": "^22.13.11",
      "lucide-react": "^0.546.0",
      "next": "16.0.0",
      "react": "19.2.0",
      "react-dom": "19.2.0",
      "@prisma/client": "^6.15.0",
      "@tailwindcss/postcss": "^4.1.10",
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "tailwindcss": "^4.1.10"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @singularity/db db:push",
    "db:studio": "turbo -F @singularity/db db:studio",
    "db:generate": "turbo -F @singularity/db db:generate",
    "db:migrate": "turbo -F @singularity/db db:migrate",
    "db:start": "turbo -F @singularity/db db:start",
    "db:watch": "turbo -F @singularity/db db:watch",
    "db:stop": "turbo -F @singularity/db db:stop",
    "db:down": "turbo -F @singularity/db db:down"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "tsdown": "^0.15.5",
    "@types/node": "^22.13.11"
  },
  "packageManager": "bun@1.3.1"
}
