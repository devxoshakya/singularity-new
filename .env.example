# ==============================================
# DODO PAYMENTS CONFIGURATION
# ==============================================

# Get your API key from https://dashboard.dodopayments.com/settings/api
# Use test mode keys for development (they start with dodo_test_)
DODO_PAYMENTS_API_KEY=dodo_test_xxxxxxxxxxxxxxxxxxxxx

# Get webhook secret from https://dashboard.dodopayments.com/webhooks
# This is used to verify webhook signatures
DODO_PAYMENTS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Your business ID from Dodo Payments dashboard
# Used for customer portal: https://customer.dodopayments.com/login/{business_id}
DODO_PAYMENTS_BUSINESS_ID=biz_xxxxxxxxxxxxxxxxxxxxx

# ==============================================
# DODO PAYMENTS PRODUCT IDS
# ==============================================

# PRO Plan - 6 Months (HALF_YEARLY)
DODO_PRODUCT_ID_PRO_HALF_YEARLY=pdt_xxxxxxxxxxxxxxxxxxxxx

# PRO Plan - 12 Months (YEARLY)
DODO_PRODUCT_ID_PRO_YEARLY=pdt_xxxxxxxxxxxxxxxxxxxxx

# PREMIUM Plan - 6 Months (HALF_YEARLY)
DODO_PRODUCT_ID_PREMIUM_HALF_YEARLY=pdt_xxxxxxxxxxxxxxxxxxxxx

# PREMIUM Plan - 12 Months (YEARLY)
DODO_PRODUCT_ID_PREMIUM_YEARLY=pdt_xxxxxxxxxxxxxxxxxxxxx

# ==============================================
# BETTER AUTH CONFIGURATION
# ==============================================

# Random secret for Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your_random_secret_here_min_32_chars

# Your API server URL where Better Auth is hosted
# This is where webhooks will be sent: {BETTER_AUTH_URL}/api/auth/webhooks/dodopayments
BETTER_AUTH_URL=https://api.yourdomain.com

# Frontend application URL
FRONTEND_URL=https://yourdomain.com

# ==============================================
# GOOGLE OAUTH CONFIGURATION
# ==============================================

# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# MongoDB connection string
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database

# Direct MongoDB URL for migrations (if using Prisma Accelerate)
DIRECT_URL=mongodb+srv://username:password@cluster.mongodb.net/database

# ==============================================
# NOTES FOR DEVELOPMENT
# ==============================================

# 1. Webhook Testing with ngrok:
#    - Run: ngrok http 8787
#    - Copy the ngrok URL
#    - In Dodo Payments dashboard, set webhook URL to: 
#      https://your-ngrok-url.ngrok.io/api/auth/webhooks/dodopayments
#    - Make sure to use the webhook secret from Dodo Payments

# 2. Product IDs:
#    - Create products in Dodo Payments dashboard
#    - Copy the product IDs (they start with pdt_)
#    - Paste them in the DODO_PRODUCT_ID_* variables above

# 3. Test Mode:
#    - The auth config uses "test_mode" environment by default
#    - Use test mode API keys (dodo_test_*)
#    - Change to "production" in packages/auth/src/index.ts when ready

# 4. Webhook Events to Enable in Dodo Dashboard:
#    ✅ subscription.created
#    ✅ subscription.activated
#    ✅ subscription.cancelled
#    ✅ subscription.expired
#    ✅ subscription.paused
#    ✅ subscription.resumed
#    ✅ subscription.renewed
#    ✅ payment.succeeded
#    ✅ payment.failed

# ==============================================
# PRODUCTION CHECKLIST
# ==============================================

# Before going live:
# [ ] Change DODO_PAYMENTS_API_KEY to production key (dodo_live_*)
# [ ] Update DODO_PAYMENTS_WEBHOOK_SECRET with production webhook secret
# [ ] Change environment to "production" in packages/auth/src/index.ts line 32
# [ ] Update BETTER_AUTH_URL to production domain (must be HTTPS)
# [ ] Update webhook URL in Dodo Payments dashboard to production domain
# [ ] Verify all product IDs are correct
# [ ] Test checkout flow with real card
# [ ] Test webhook delivery
# [ ] Monitor logs for any errors
