
type CarryOver {
  sem   String
  cop   String
  name  String?
}

type Subject {
  code      String
  name      String
  type      String
  internal  String
  external  String
  backPaper String
  grade     String
}

type Semester {
  semester           String
  evenOdd            String
  totalMarksObtained Int
  resultStatus       String
  SGPA               Float
  dateOfDeclaration  String
  subjects           Subject[] // Array of embedded Subject documents
}



model Result {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  rollNo             String      @unique
  enrollmentNo       String
  fullName           String
  fatherName         String
  course             String
  branch             String
  instituteName      String
  
  blocked            Boolean     @default(false)
  year               Int?

  cgpa               String      @default("")
  divison            String      @default("") 
  totalMarksObtained Int         @default(0)
  latestResultStatus String      @default("")
  latestCOP          String      @default("")

  // Strictly typed arrays of embedded documents
  CarryOvers         CarryOver[] 
  semesters          Semester[]  

  @@map("result")
}