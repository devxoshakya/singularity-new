generator client {
  provider = "prisma-client-js"
  moduleFormat = "esm"
  runtime = "workerd"
  engineType = "edge"
}

datasource db {
  provider = "mongodb"
  directUrl = env("DIRECT_URL")
  url      = env("DATABASE_URL")
}


model Test {
  id        String    @id @default(uuid()) @map("_id")
  name      String
  email     String
  @@map("test")
}
